# SYS.HEALTH — variáveis de ambiente (copie para .env.local)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Opcional (escrita server-side sem RLS restritivo)
SUPABASE_SERVICE_ROLE_KEY=

# Zepp / Amazfit
# ZEPP_BEARER_TOKEN tem prioridade; se vazio, usa ZEPP_APP_TOKEN
ZEPP_BEARER_TOKEN=
ZEPP_APP_TOKEN=
ZEPP_USER_ID=

# Hevy (treinos)
HEVY_API_KEY=

# Telegram (opcional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Google Gemini AI (opcional)
GEMINI_API_KEY=
