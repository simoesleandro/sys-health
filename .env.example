# SYS.HEALTH — variáveis de ambiente (copie para .env.local)

# Supabase — Settings → API → Project URL (formato: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Legacy: anon public (eyJ...) ou nova: sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Legacy: service_role secret (eyJ...) ou nova: sb_secret_... — só no servidor/Vercel
SUPABASE_SERVICE_ROLE_KEY=

# Zepp / Amazfit
# ZEPP_BEARER_TOKEN tem prioridade; se vazio, usa ZEPP_APP_TOKEN
ZEPP_BEARER_TOKEN=
ZEPP_APP_TOKEN=
ZEPP_USER_ID=

# Hevy (treinos)
HEVY_API_KEY=

# Google Calendar (aba Agenda em Hoje — somente leitura)
# Gere GOOGLE_REFRESH_TOKEN: node scripts/get-gcal-token.mjs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Opcional — default: primary
# GOOGLE_CALENDAR_ID=primary

# Telegram (opcional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Google Gemini AI — local (.env.local) e Vercel (NÃO no Supabase)
# Coach (/ia-coach) e análise de refeição (texto/foto no modal + Refeição)
GEMINI_API_KEY=
# Alias aceito pelo AI SDK:
# GOOGLE_GENERATIVE_AI_API_KEY=
# Modelo (opcional; default gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash
